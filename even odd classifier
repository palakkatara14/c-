using System;

class Number
{
    public void Check(int n)
    {
        if (n % 2 == 0)
            Console.WriteLine("Even");
        else
            Console.WriteLine("Odd");
    }
}

class Program
{
    static void Main()
    {
        Console.Write("Enter number: ");
        int n = int.Parse(Console.ReadLine());

        Number obj = new Number();
        obj.Check(n);
    }
}
